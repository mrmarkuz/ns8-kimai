{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "local>NethServer/.github:ns8-automerge"
    ],
	"packageRules": [
        {
            "matchPackageNames": [
                "kimai/kimai2"
            ],
            "versioning": "regex:^apache-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)"
        },
        {
            "matchPackageNames": [
                "mariadb"
            ],
            "allowedVersions": "<= 10.11"
	    }
    ]
}
